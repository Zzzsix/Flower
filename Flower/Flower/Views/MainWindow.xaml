<Window x:Class="Flower.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Flower"
        xmlns:vm="clr-namespace:Flower.ViewModels"
        xmlns:helpers="clr-namespace:Flower.Helpers"
        Title="Flower" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#5d4e64">
            <MenuItem Header="_文件" Height="22" Background="#5d4e64">
                <MenuItem Header="打开文件夹..." Command="{Binding LoadFolderCommand}"/>
                <Separator/>
                <MenuItem Header="退出" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
        </Menu>

        <!--主显示区-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="30" MaxWidth="640"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 文件夹树 -->
            <TreeView x:Name="FolderTreeView"
                      Grid.Column="0"
                      Background="#4A3E4F"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemsSource="{Binding Roots}"
                      SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" 
                                Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            
            <!--拖拽分割线-->
            <GridSplitter Grid.Column="1"
                          Width="2"
                          ResizeBehavior="PreviousAndNext"
                          Background="#DDD"/>

            <!-- 右侧缩略图区域 -->
            <ListBox Grid.Column="2"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding Images}"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <helpers:WaterfallPanel ColumnWidth="160" Spacing="4"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FileItemViewModel}">
                        <Border Background="#F0F0F0" CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                </Grid.RowDefinitions>
                                <!-- 图片按比例缩放，宽度固定160，高度自适应 -->
                                <Image Grid.Row="0" Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                <TextBlock Grid.Row="1" Text="{Binding Name}" 
                                           TextTrimming="CharacterEllipsis" FontSize="9"
                                           Margin="2,0" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

        <!-- 状态栏预留 -->
        <StatusBar Grid.Row="2" Background="#5d4e64">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Orange" />
        </StatusBar>

    </Grid>
</Window>
